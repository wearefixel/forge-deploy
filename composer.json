{
  "name": "fixel/forge-deploy",
  "autoload": {
    "psr-4": {
      "Fixel\\ForgeDeploy\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Fixel\\ForgeDeploy\\Tests\\": "tests"
    }
  },
  "require": {
    "statamic/cms": "^6.0",
    "gitonomy/gitlib": "^1.6"
  },
  "require-dev": {
    "orchestra/testbench": "^10.8"
  },
  "config": {
    "allow-plugins": {
      "pixelfear/composer-dist-plugin": true
    }
  },
  "extra": {
    "statamic": {
      "name": "Statamic Forge Deploy",
      "description": "Statamic Forge Deploy addon"
    },
    "laravel": {
      "providers": [
        "Fixel\\ForgeDeploy\\ServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
